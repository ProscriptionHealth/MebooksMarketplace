# Mebooks.ai Environment Configuration

# Vector Search Service Configuration
VECTOR_SEARCH_SERVICE_URL=http://localhost:8000
VECTOR_SEARCH_HOST=0.0.0.0
VECTOR_SEARCH_PORT=8000

# Google Cloud Configuration (for Python Vector Search Service)
GOOGLE_CLOUD_PROJECT_ID=your-project-id
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account.json

# Gemini AI Configuration
GEMINI_API_KEY=your-gemini-api-key

# Database Configuration
DATABASE_URL=your-database-url

# Application Configuration
NODE_ENV=development
PORT=5000