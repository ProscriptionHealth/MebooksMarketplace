# Mebooks.ai Environment Configuration

# Vector Search Service Configuration
VECTOR_SEARCH_SERVICE_URL=http://localhost:8000
VECTOR_SEARCH_HOST=0.0.0.0
VECTOR_SEARCH_PORT=8000

# Redis Configuration
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Google Cloud Configuration (for Python Vector Search Service)
GOOGLE_CLOUD_PROJECT_ID=your-project-id
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account.json

# Gemini AI Configuration
GEMINI_API_KEY=your-gemini-api-key

# Database Configuration
DATABASE_URL=your-database-url

# Application Configuration
NODE_ENV=development
PORT=5000

# Docker and Deployment Configuration
VECTOR_SEARCH_API_KEY=your-vector-search-api-key
API_KEY=your-general-api-key
POSTGRES_PASSWORD=secure-postgres-password

# Frontend Environment Variables (Vite)
VITE_VECTOR_SEARCH_API_URL=http://localhost:5000
VITE_GEMINI_API_KEY=your-gemini-api-key