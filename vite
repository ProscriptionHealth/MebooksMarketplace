#!/usr/bin/env node
import { spawn } from 'child_process';

// Always start vite with port 5000 and host 0.0.0.0 for Replit compatibility
const args = ['vite'];

// Add port and host arguments if not already present
if (!process.argv.includes('--port')) {
  args.push('--port', '5000');
}
if (!process.argv.includes('--host')) {
  args.push('--host', '0.0.0.0');
}

// Add any additional arguments passed to this script
args.push(...process.argv.slice(2));

const vite = spawn('npx', args, {
  stdio: 'inherit',
  env: process.env
});

vite.on('error', (error) => {
  console.error('Failed to start vite:', error);
  process.exit(1);
});

vite.on('close', (code) => {
  process.exit(code);
});

process.on('SIGINT', () => {
  vite.kill('SIGINT');
});

process.on('SIGTERM', () => {
  vite.kill('SIGTERM');
});